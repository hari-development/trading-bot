# Trading Bot — Environment Variables
# Copy this file to .env and fill in real values.
# NEVER commit .env to Git — it contains secrets.

# ── Kite Connect (only needed for LIVE mode) ──────────────────────────────────
# Generate these from https://developers.kite.trade/
# KITE_ACCESS_TOKEN expires daily — see README for the daily refresh script.
KITE_API_KEY=your_api_key_here
KITE_API_SECRET=your_api_secret_here
KITE_ACCESS_TOKEN=your_daily_access_token_here

# ── Optional: Telegram alerts ─────────────────────────────────────────────────
# Create a bot via @BotFather, get the chat ID from @userinfobot
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ── Runtime ───────────────────────────────────────────────────────────────────
# PAPER | LIVE  (can also pass --mode flag to main.py)
BOT_MODE=PAPER
